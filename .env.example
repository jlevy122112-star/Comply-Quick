# Comply-Quick environment template
# Copy this file to .env.local (or set in your hosting dashboard) and fill in the values.
# Never commit .env.local or any file containing real secrets.
PLATFORM_ADMIN_EMAILS=

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── App hosts ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_HOST=localhost

# ─── Stripe core ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Stripe subscription Price IDs ───────────────────────────────────────────
# Monthly/annual prices for each paid tier. Annual = 10x monthly.
STRIPE_PRICE_SOLO_MONTHLY=price_...
STRIPE_PRICE_SOLO_ANNUAL=price_...
STRIPE_PRICE_AGENCY=price_...
STRIPE_PRICE_AGENCY_ANNUAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...

# ─── Stripe metered billing event names ──────────────────────────────────────
# Create Billing Meters in Stripe and paste their event_name values here.
STRIPE_METER_API_CALL=...
STRIPE_METER_TEMPLATE_UPLOAD=...
STRIPE_METER_EXTRA_SCAN=...

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
NOTIFICATIONS_FROM_EMAIL=noreply@example.com

# ─── Scanner worker ──────────────────────────────────────────────────────────
SCANNER_WORKER_URL=http://localhost:8080
SCANNER_WORKER_SECRET=dev-secret

# ─── GitHub integration ──────────────────────────────────────────────────────
GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...

# ─── Cron / admin endpoints ──────────────────────────────────────────────────
CRON_SECRET=random-secret-for-cron-endpoints

# ─── AI (optional, disables AI features if unset) ────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Sentry (optional) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...
SENTRY_AUTH_TOKEN=sntrys_...

# ─── Analytics (optional) ────────────────────────────────────────────────────
NEXT_PUBLIC_GA4_ID=G-...
NEXT_PUBLIC_CLARITY_ID=...

# ─── Marketplace / Stripe Connect (optional) ─────────────────────────────────
STRIPE_PLATFORM_ACCOUNT_ID=acct_...

# ─── Scanner tuning (optional) ───────────────────────────────────────────────
# SCAN_NAV_TIMEOUT_MS=30000
# SCAN_SETTLE_MS=2500

# ─── AI model (optional) ─────────────────────────────────────────────────────
# OPENAI_MODEL=gpt-4o-mini

# ─── Sentry build configuration (optional) ───────────────────────────────────
# SENTRY_DSN=https://...
# SENTRY_ORG=comply-quick
# SENTRY_PROJECT=javascript-nextjs
# SENTRY_AUTH_TOKEN=sntrys_...

# ─── Caching / rate limiting (optional) ──────────────────────────────────────
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# ─── Domain / DNS management (optional) ──────────────────────────────────────
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ZONE_ID=...

# ─── Vercel automation (optional) ────────────────────────────────────────────
# VERCEL_API_TOKEN=...
# VERCEL_PROJECT_ID=...
# VERCEL_TEAM_ID=...

# ─── Single sign-on (optional) ───────────────────────────────────────────────
# SSO_PROVIDER_URL=https://...

# ─── Feature flags (optional) ────────────────────────────────────────────────
# NEXT_PUBLIC_ENABLE_SPEED_OPTIMIZATIONS=true
# NEXT_PUBLIC_ENABLE_PROFIT_OPTIMIZATIONS=true
# NEXT_PUBLIC_ENABLE_CHURN_SAVE_OFFER=false
# NEXT_PUBLIC_EXPERIMENT_PRICING_V1_FORCE=

# ─── SEO / performance (optional) ────────────────────────────────────────────
# NEXT_PUBLIC_GSC_VERIFICATION=...
# PERF_BUDGET_LANDING_JS_KB=200

# ─── Content Security Policy mode (optional) ─────────────────────────────────
# CSP_MODE=report-only

# ─── Internal admin / notification emails (optional) ─────────────────────────
# MARKETPLACE_ADMIN_EMAILS=admin@example.com
# LEGAL_REVIEW_ADMIN_EMAILS=admin@example.com
# PMF_ADMIN_EMAILS=admin@example.com

# ─── Leads export token (optional) ───────────────────────────────────────────
# LEADS_EXPORT_TOKEN=random-token

# ─── Logging (optional) ──────────────────────────────────────────────────────
# LOG_LEVEL=info

# ─── Testing / scripts (optional, local/dev only) ────────────────────────────
# SMOKE_BASE_URL=http://localhost:3000
# SMOKE_PORT=3000
# SMOKE_BUDGET_MS=5000
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# PLAYWRIGHT_TEST_EMAIL=test@example.com
# PLAYWRIGHT_TEST_PASSWORD=password
