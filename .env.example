# Public Supabase project settings. Copy to .env.local for local development.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only Supabase administrative credential. Never expose this to browser code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Canonical public origin used for email confirmation, magic-link, and password-reset callbacks.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Stripe billing. Use live-mode values only in the production hosting environment.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO_MONTHLY=
STRIPE_PRICE_SOLO_ANNUAL=
STRIPE_PRICE_AGENCY=
STRIPE_PRICE_AGENCY_ANNUAL=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_ENTERPRISE_ANNUAL=

# Optional production observability settings. The public DSN is safe for browser
# delivery; the auth token must remain server/build-only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=comply-quick
SENTRY_PROJECT=javascript-nextjs
SENTRY_AUTH_TOKEN=

# Optional AI-assisted features. Do not set these unless those features are enabled.
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional distributed rate limiting and scanner worker integration.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
SCANNER_WORKER_URL=
SCANNER_WORKER_SECRET=

# Server-only scheduled-job and administrative endpoints.
CRON_SECRET=
LEADS_EXPORT_TOKEN=
LEGAL_REVIEW_ADMIN_EMAILS=
MARKETPLACE_ADMIN_EMAILS=
PMF_ADMIN_EMAILS=
